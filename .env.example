# Anthropic API key — required for the PST Companion and LTspice Agent
ANTHROPIC_API_KEY=your_api_key_here

# LTspice server URL — the MacBook running ltspice-server/server.js on your LAN
# Find your MacBook's LAN IP: System Preferences → Network → IP Address
# Default port is 8765
LTSPICE_SERVER_URL=http://192.168.1.xxx:8765

# Optional overrides
# PORT=3001        # Express backend port
# DATA_DIR=./data  # Path to directory containing products.xlsx

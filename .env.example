# Anthropic API key — required for the LTspice Agent (and PST Companion)
ANTHROPIC_API_KEY=your_api_key_here

# LTspice MacBook LAN address
# The MacBook running ltspice-server/ is on 192.168.0.70
LTSPICE_SERVER_URL=http://192.168.0.70:8765

# Workbench server port (default 3002, PST uses 3001)
# PORT=3002

# PST server port (default 3001)
# PORT=3001
